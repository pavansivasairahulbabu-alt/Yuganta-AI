# Environment
# Set to 'development' for local development, 'production' for deployment
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=your_mongodb_connection_string_here

# JWT - Change to a long random string for production
JWT_SECRET=change_this_to_a_very_long_random_string_for_production

# Frontend URL (for CORS and email redirects)
# Development: http://localhost:5173
# Production: https://yugantaai.vercel.app
FRONTEND_URL=http://localhost:5173


GOOGLE_CLIENT_ID=your_google_client_id_here

# Email Configuration (Brevo/Sendinblue)
# Get API key from: https://app.brevo.com
# Used for OTP and transactional emails
BREVO_API_KEY=your_brevo_api_key_here
BREVO_FROM_EMAIL=noreply@yourdomain.com

# Cloudinary (for file uploads - optional)
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here